# Copy to .env and fill in as needed:  copy .env.example .env   (Windows)
# Default run is rules-only, offline, deterministic.

USE_LLM=false
LLM_PROVIDER=openai
OPENAI_API_KEY=

# OCR engine for scanned documents
OCR_ENGINE=tesseract
# Windows only: if tesseract.exe is not on PATH, put its full path here, e.g.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=

# Where run artifacts are written
RUN_DIR=runs
